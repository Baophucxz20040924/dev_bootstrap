# Nginx config cho Dev Bootstrap Platform (chạy trên máy server)
#
# Frontend (bản build trong web/dist) được serve tĩnh ở port 80.
# Các đường /api, /install, /bin được proxy sang backend Node (port 4000).
#
# Cài đặt:
#   1. Build frontend:  cd web && npm run build   -> ra thư mục web/dist
#   2. Copy file này vào nginx (Windows: C:\nginx\conf\ ; Linux: /etc/nginx/conf.d/)
#   3. Sửa `root` bên dưới cho đúng đường dẫn tới web/dist trên máy server
#   4. Reload nginx:  nginx -s reload   (hoặc restart service)

server {
    listen 80;
    server_name _;

    # Đường dẫn tuyệt đối tới thư mục build của frontend.
    # Windows ví dụ: C:/Users/DHA-PHUCNGUYENBAO/Desktop/auto-devops/web/dist
    root C:/Users/DHA-PHUCNGUYENBAO/Desktop/auto-devops/web/dist;
    index index.html;

    # API của backend.
    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Endpoint sinh script one-line install (curl/irm gọi thẳng vào đây).
    location /install/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Binary do platform host (devsecops CLI...).
    location /bin/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # SPA fallback: mọi route khác trả về index.html để React Router xử lý.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
